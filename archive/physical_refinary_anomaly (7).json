      "parameters": {
        "jsCode": "const staticData = $getWorkflowStaticData('global');\nstaticData.requested_tank = $json.requested_tank;\n\nreturn {\n  requested_tank: $json.requested_tank\n};\n"
      },
      "type": "n8n-nodes-base.code",
