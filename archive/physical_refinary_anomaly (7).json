    {
      "parameters": {
        "jsCode": "return items.map(item => {\n  let intense = 0;\n  const tank = item.json;\n  if (tank.anomaly === 1) intense += 2;\n  if (tank.lowest_score < -0.1) intense += 2;\n\n  // 3. Check for specific dangerous types in the anomalies list\n  const hasImpossibleValue = tank.anomalies.some(a => a.type === 'impossible_value');\n  const hasSensorFault = tank.anomalies.some(a => a.type === 'sensor_fault');\n  const hasSuddenSpike = tank.anomalies.some(a => a.type === 'sudden_spike');\n\n  if (hasImpossibleValue) intense += 2; // Very high priority\n  if (hasSuddenSpike) intense += 1;     // Moderate priority\n  if (hasSensorFault) intense += 1;     // Equipment maintenance needed\n\n  // 4. Night-time weighting (Optional: based on your Python 'is_night' feature)\n  // We can check the first anomaly's timestamp to see if it happened at night\n  if (tank.anomalies.length > 0) {\n      const lastAnomalyHour = new Date(tank.anomalies[0].timestamp).getHours();\n      if (lastAnomalyHour >= 22 || lastAnomalyHour <= 5) {\n          intense += 1; // Higher priority if no one is on-site\n      }\n  }\n\n  // Define levels based on intensity\n  let level = \"Normal\";\n  if (intense >= 4) level = \"Critical\";\n  else if (intense >= 2) level = \"Warning\";\n\n  return {\n    json: {\n      ...item.json,\n      intense,\n      level\n    }\n  };\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1616,
        -16
      ],
      "id": "36cf1457-4788-4173-b8f4-9550eeeaf3e3",
      "name": "Code2"
