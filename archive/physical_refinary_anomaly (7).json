    {
      "parameters": {
        "jsCode": "const staticData = $getWorkflowStaticData('global');\nlet requestedTank = staticData.requested_tank;\n\n// 1. Check if tank is requested (Static Data or Code1)\nif (!requestedTank) {\n    try {\n        requestedTank = $('Code1').first()?.json?.requested_tank;\n    } catch (e) {\n        requestedTank = null;\n    }\n}\n\n// 2. Normalization Function\nconst normalize = (id) => {\n    if (!id) return \"\";\n    let str = String(id).toLowerCase().trim();\n    // physical_7 -> physical_07, but physical_07 remains physical_07\n    return str.replace(/physical_(\\d)$/, 'physical_0$1');\n};\n\n// 3. LOGIC CHECK\nif (requestedTank) {\n    // CASE: User has requested a specific tank\n    const targetId = normalize(requestedTank);\n    \n    const filteredItems = items.filter(item => {\n        if (!item.json.tank_id) return false;\n        return normalize(item.json.tank_id) === targetId;\n    });\n\n    // CRITICAL: Agar user ne tank manga hai, to sirf filtered items bhejo.\n    // Agar is branch mein tank nahi mila, to empty array jayega (jo ke sahi hai).\n    return filteredItems;\n\n} else {\n    // CASE: Schedule Trigger (No specific tank requested)\n    // Is surat mein saara data wese hi return kar do.\n    return items;\n}"
      },
