    {
      "parameters": {
        "jsCode": "return items.map(item => ({\n  json: {\n    tank_id: (item.json.tank_id || \"Unknown\")\n      .toString()\n      .trim()\n      .toLowerCase()\n      .replace(/([a-z])([0-9])/g, '$1_$2'), \n    level_feet: Number(item.json.level_feet),\n    sensor_timestamp: item.json.sensor_timestamp\n  }\n}));"
      },
