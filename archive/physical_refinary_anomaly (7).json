    {
      "parameters": {
        "jsCode": "const input = $json.Inputfield || $json.text || \"\";\nconst message = input.toString().toLowerCase();\n\n// Extract just the numbers from the input\nlet match = message.match(/\\d+/);\nlet formattedTank = null;\n\nif (match) {\n  // Always force two digits with a leading zero\n  const tankNum = match[0].padStart(2, '0');\n  formattedTank = `physical_${tankNum}`;\n}\n\nreturn {\n  requested_tank: formattedTank,\n  original_input: input\n};"
      },
